{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nom de la pi\u00e8ce"
    },
    "slug": {
      "type": "string",
      "description": "Identifiant URL unique"
    },
    "description": {
      "type": "string",
      "description": "Description de la pi\u00e8ce"
    },
    "category": {
      "type": "string",
      "enum": [
        "moteur",
        "carrosserie",
        "freinage",
        "circuit",
        "cadre",
        "admission"
      ],
      "description": "Cat\u00e9gorie de la pi\u00e8ce"
    },
    "price": {
      "type": "number",
      "description": "Prix de base en euros"
    },
    "customizable": {
      "type": "boolean",
      "default": true,
      "description": "Pi\u00e8ce personnalisable en couleur"
    },
    "order_type": {
      "type": "string",
      "enum": [
        "panier",
        "devis",
        "les deux"
      ],
      "default": "panier"
    },
    "available_colors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Couleurs disponibles (hex)"
    },
    "color_parts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "part_name": {
            "type": "string"
          },
          "default_color": {
            "type": "string"
          }
        }
      },
      "description": "Zones colorables de la pi\u00e8ce"
    },
    "image_url": {
      "type": "string"
    },
    "model_3d_url": {
      "type": "string",
      "description": "URL fichier 3D optionnel"
    },
    "in_stock": {
      "type": "boolean",
      "default": true
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "compatible_models": {
      "type": "string",
      "description": "Ex: Derbi, MBK, Yamaha Aerox..."
    }
  },
  "required": [
    "name",
    "price"
  ]
}
